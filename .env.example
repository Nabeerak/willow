# Gemini API Configuration
# Use GEMINI_API_KEY — the SDK prefers this over GOOGLE_API_KEY when both are set
GEMINI_API_KEY=your_api_key_here

# Gemini Model ID — must support bidiGenerateContent (Gemini Live API)
GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025

# Session Configuration
SESSION_TIMEOUT_SECONDS=3600

# Latency Configuration
MIN_FILLER_LATENCY_MS=200

# Google Cloud Platform
GCP_PROJECT_ID=willow-agent

# Hash validation — set true to skip Secret Manager check in local dev
SKIP_HASH_VALIDATION=true

# Logging
ENABLE_CLOUD_LOGGING=false
LOG_LEVEL=INFO

# Tier Latency Budgets (ms)
TIER1_BUDGET_MS=50
TIER2_BUDGET_MS=5
TIER3_BUDGET_MS=500
TIER4_BUDGET_MS=2000
